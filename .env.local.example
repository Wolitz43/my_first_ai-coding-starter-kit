# Supabase (Optional - remove if not using backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service Role Key – NEVER use NEXT_PUBLIC_ prefix, never expose in browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL (used for auth redirects after signout)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Ticketmaster Discovery API – used by the Vercel Cron Job (/api/cron/ticketmaster)
# Get your free API key at: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your-ticketmaster-api-key-here

# Vercel Cron Secret – protects the cron endpoint from unauthorized calls
# Generate with: openssl rand -base64 32
CRON_SECRET=your-random-secret-here

# Add more environment variables as needed
# STRIPE_SECRET_KEY=sk_...
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
